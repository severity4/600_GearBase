# Database (Railway PostgreSQL plugin will auto-set DATABASE_URL)
DATABASE_URL=postgresql://user:password@localhost:5432/gearbase

# Server
PORT=3000
NODE_ENV=production

# Auth
JWT_SECRET=change-this-to-a-secure-random-string

# Email (optional - system works without it)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM_NAME=映奧創意工作室
